#!/bin/bash
# bin/playbook-grok — launch Grok Build CLI with a unique per-session Playbook session ID.
#
# Usage: playbook-grok [grok-args...]
#
# Generates PLAYBOOK_SESSION_ID, provisions the session directory, then execs
# grok so the agent (and every hook process it spawns) inherits the env.
#
# Enforcement channel (task 020): always-trusted
# ~/.grok/hooks/playbook-enforcement.json — written by
# `tasks init --provider grok` (auto-installs hooks). Required on spaced
# project paths (iCloud) where project/plugin hooks never schedule.
# Restart the Grok session after install/upgrade so hooks reload.
# Project-level hooks (monitor-nudge, etc.) still need /hooks-trust once.
# Payload dialect: scripts/hook-payload-normalize.py (camelCase + tool
# renames write/search_replace/run_terminal_command). Stop cannot block
# (soft anti-walk-away, same boundary as pi).
#
# See provider/adapters/grok.py launch_interactive() for the programmatic
# equivalent (assumes env pre-set).

set -e

# Find project root (directory containing .agent/tasks/)
find_project_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.agent/tasks" ]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    echo ""
}

PROJECT_ROOT="$(find_project_root)"

# PID-based session ID: pid-$$ (this wrapper's PID = parent of grok process)
SESSION_ID="pid-$$"
export PLAYBOOK_SESSION_ID="$SESSION_ID"
export PLAYBOOK_PROJECT_ROOT="$PROJECT_ROOT"
# So chat-log-hook tags this session's messages `grok`, not the default `claude`.
export PLAYBOOK_PROVIDER="grok"

# Provision session directory so state files have a home
if [ -n "$PROJECT_ROOT" ]; then
    mkdir -p "$PROJECT_ROOT/.agent/sessions/$SESSION_ID"
fi

exec grok "$@"
