#!/bin/bash
# scripts/init — mechanical project setup for playbook plugin
#
# Creates .agent/tasks/, .claude/bin/ wrappers, settings.json permissions,
# and MIND_MAP.md stub. Safe to re-run (idempotent).
#
# Usage: scripts/init [project-display-name]
#   Operates on cwd (assumes cwd = target project root).
#   $1 = optional display name for MIND_MAP.md (default: basename of cwd).

set -e

# Source shared lib (same directory as this script)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/gate-echo-lib.sh"

PROJECT_DIR="$PWD"
PROJECT_NAME="${1:-$(basename "$PWD")}"

CREATED=()
SKIPPED=()
FAILED=()

# --- (a) .agent/tasks/ ---
if [ ! -d "$PROJECT_DIR/.agent/tasks" ]; then
    mkdir -p "$PROJECT_DIR/.agent/tasks"
    CREATED+=(".agent/tasks/")
else
    SKIPPED+=(".agent/tasks/ (exists)")
fi

# --- (a2) .agent/playbooks/ + README ---
PLAYBOOKS_DIR="$PROJECT_DIR/.agent/playbooks"
if [ ! -d "$PLAYBOOKS_DIR" ]; then
    mkdir -p "$PLAYBOOKS_DIR"
    # Copy README from the SAME plugin copy this script runs from (a global
    # find could mix versions); deterministic sorted find only as fallback.
    if [ -f "$SCRIPT_DIR/playbooks-README.md" ]; then
        cp "$SCRIPT_DIR/playbooks-README.md" "$PLAYBOOKS_DIR/README.md"
    else
        PLUGIN_README=$(find ~/.claude/plugins -path '*/playbook/scripts/playbooks-README.md' 2>/dev/null | sort | head -1)
        if [ -n "$PLUGIN_README" ]; then
            cp "$PLUGIN_README" "$PLAYBOOKS_DIR/README.md"
        fi
    fi
    CREATED+=(".agent/playbooks/")
else
    SKIPPED+=(".agent/playbooks/ (exists)")
fi

# --- (a3) .agent/config.json — per-install review knobs ---
# Install-wide, hand-editable. Precedence for each setting: CLI flag > env var >
# this file > built-in default. Only written when absent — never clobbers a
# user-tuned file. (Values here are the built-in defaults, spelled out so the
# knobs are discoverable.)
CONFIG_JSON="$PROJECT_DIR/.agent/config.json"
if [ ! -f "$CONFIG_JSON" ]; then
    mkdir -p "$PROJECT_DIR/.agent"
    cat > "$CONFIG_JSON" <<'CONFIG'
{
  "_doc": "Per-install playbook review settings. Precedence: CLI flag > env var > this file > default. judge_budget_usd caps the claude judge's --max-budget-usd (claude backend only; codex/agy/pi have no budget knob). review_timeout_secs bounds every review agent (plan/impl/panel). Env overrides: PLAYBOOK_JUDGE_BUDGET_USD, PLAYBOOK_REVIEW_TIMEOUT_SECS.",
  "judge_budget_usd": 2,
  "review_timeout_secs": 300
}
CONFIG
    CREATED+=(".agent/config.json")
else
    SKIPPED+=(".agent/config.json (exists)")
fi

# On Git-Bash/MSYS, python3 is usually native Windows Python, which cannot open
# MSYS-style paths (/c/Users/...). Convert to a mixed-mode Windows path
# (C:/Users/...) — forward slashes so it's also safe inside a Python string
# literal — before handing a path to python3. No-op on real POSIX, where
# cygpath is absent and the original path is echoed unchanged.
to_native_path() {
    cygpath -m "$1" 2>/dev/null || echo "$1"
}

# --- (b) settings.json permissions.deny merge ---
SETTINGS_FILE="$PROJECT_DIR/.claude/settings.json"
mkdir -p "$PROJECT_DIR/.claude"
SETTINGS_FILE_PY="$(to_native_path "$SETTINGS_FILE")"

SETTINGS_RESULT=$(python3 -c "
import json, sys, os

path = '$SETTINGS_FILE_PY'
required = ['TodoWrite', 'Task', 'EnterPlanMode']

try:
    if os.path.exists(path):
        with open(path) as f:
            data = json.load(f)
        if not isinstance(data, dict):
            print('ERROR:settings.json root is not an object', file=sys.stderr)
            sys.exit(1)
    else:
        data = {}

    perms = data.setdefault('permissions', {})
    deny = perms.setdefault('deny', [])
    added = []
    for item in required:
        if item not in deny:
            deny.append(item)
            added.append(item)

    if added:
        with open(path, 'w') as f:
            json.dump(data, f, indent=2)
            f.write('\n')
        print('CREATED:' + ','.join(added))
    else:
        print('SKIPPED')
except json.JSONDecodeError as e:
    print(f'ERROR:settings.json is malformed JSON: {e}', file=sys.stderr)
    sys.exit(1)
" 2>&1) || {
    FAILED+=("settings.json ($SETTINGS_RESULT)")
    SETTINGS_RESULT=""
}

if [ -n "$SETTINGS_RESULT" ]; then
    case "$SETTINGS_RESULT" in
        CREATED:*)
            CREATED+=("settings.json deny: ${SETTINGS_RESULT#CREATED:}")
            ;;
        SKIPPED)
            SKIPPED+=("settings.json (already has deny list)")
            ;;
        ERROR:*)
            FAILED+=("settings.json: ${SETTINGS_RESULT#ERROR:}")
            ;;
    esac
fi

# --- (c) MIND_MAP.md stub ---
if [ ! -f "$PROJECT_DIR/MIND_MAP.md" ]; then
    echo "# Mind Map — $PROJECT_NAME" > "$PROJECT_DIR/MIND_MAP.md"
    CREATED+=("MIND_MAP.md (stub — run /mindmap to populate)")
else
    SKIPPED+=("MIND_MAP.md (exists)")
fi

# --- (d) .claude/bin/ wrappers ---
create_wrapper "$PROJECT_DIR" tasks
if [ -f "$PROJECT_DIR/.claude/bin/tasks" ]; then
    CREATED+=(".claude/bin/tasks")
fi

create_wrapper "$PROJECT_DIR" sandbox
if [ -f "$PROJECT_DIR/.claude/bin/sandbox" ]; then
    CREATED+=(".claude/bin/sandbox")
fi

# Provider launchers: thin find-and-exec wrappers so each provider's gate-hooked
# entry point is reachable as .claude/bin/playbook-<x> in any project (the plugin
# scripts/ dir is not on PATH). Generated uniformly; running one whose CLI isn't
# installed just errors at exec time.
for provider_wrapper in playbook-codex playbook-agy playbook-pi; do
    create_wrapper "$PROJECT_DIR" "$provider_wrapper"
    if [ -f "$PROJECT_DIR/.claude/bin/$provider_wrapper" ]; then
        CREATED+=(".claude/bin/$provider_wrapper")
    fi
done

# --- (e) bash history logging ---
# BEGIN:bash-log
SHELL_NAME="$(basename "$SHELL" 2>/dev/null)"
if [ "$SHELL_NAME" = "zsh" ]; then
    BASH_LOG_FILE="bash-log.zsh"
    RC_FILE="$HOME/.zshenv"
    SOURCE_LINE='[ -f ~/.claude/bash-log.zsh ] && source ~/.claude/bash-log.zsh'
else
    BASH_LOG_FILE="bash-log.sh"
    # ~/.bashrc is interactive-only; CC runs non-interactive bash.
    # BASH_ENV is sourced by bash for every non-interactive shell — the right hook.
    # Prefer ~/.bash_profile (login shell sets env for all children); fall back to ~/.profile.
    if [ -f "$HOME/.bash_profile" ] || [ ! -f "$HOME/.profile" ]; then
        RC_FILE="$HOME/.bash_profile"
    else
        RC_FILE="$HOME/.profile"
    fi
    SOURCE_LINE='export BASH_ENV=~/.claude/bash-log.sh'
fi

BASH_LOG_SRC="$SCRIPT_DIR/$BASH_LOG_FILE"
BASH_LOG_DEST="$HOME/.claude/$BASH_LOG_FILE"

if [ -f "$BASH_LOG_SRC" ]; then
    mkdir -p "$HOME/.claude"
    if [ ! -f "$BASH_LOG_DEST" ]; then
        cp "$BASH_LOG_SRC" "$BASH_LOG_DEST"
        CREATED+=("~/.claude/$BASH_LOG_FILE")
    elif diff -q "$BASH_LOG_SRC" "$BASH_LOG_DEST" > /dev/null 2>&1; then
        SKIPPED+=("~/.claude/$BASH_LOG_FILE (unchanged)")
    else
        cp "$BASH_LOG_SRC" "$BASH_LOG_DEST"
        CREATED+=("~/.claude/$BASH_LOG_FILE (updated)")
    fi

    if grep -qF 'claude/bash-log' "$RC_FILE" 2>/dev/null; then
        SKIPPED+=("$RC_FILE (source line exists)")
    else
        { echo ""; echo "# claude-playbook: command logging"; echo "$SOURCE_LINE"; } >> "$RC_FILE"
        CREATED+=("$RC_FILE (source line added)")
    fi

    # Inject BASH_ENV into ~/.claude/settings.json so CC passes it to every bash shell it spawns.
    # This is the reliable path — CC reads settings.json env key and injects vars before tool calls.
    CC_SETTINGS="$HOME/.claude/settings.json"
    CC_SETTINGS_PY="$(to_native_path "$CC_SETTINGS")"
    BASH_ENV_RESULT=$(python3 -c "
import json, os, tempfile
path = '$CC_SETTINGS_PY'
# Always bash-log.sh — CC's Bash tool is /bin/bash regardless of user's login shell.
# Forward-slash the path: on Windows expanduser yields backslashes, but BASH_ENV
# is read by Git-Bash which needs a POSIX-sourceable path (C:/Users/... works).
dest = os.path.expanduser('~/.claude/bash-log.sh').replace(os.sep, '/')
try:
    data = json.loads(open(path).read()) if os.path.exists(path) else {}
    env = data.setdefault('env', {})
    if env.get('BASH_ENV') == dest:
        print('SKIPPED')
    else:
        env['BASH_ENV'] = dest
        tmp = path + '.tmp'
        open(tmp, 'w').write(json.dumps(data, indent=2) + '\n')
        os.replace(tmp, path)
        print('CREATED')
except Exception as e:
    print('ERROR:' + str(e))
" 2>&1)
    case "$BASH_ENV_RESULT" in
        CREATED)  CREATED+=("~/.claude/settings.json (BASH_ENV set)") ;;
        SKIPPED)  SKIPPED+=("~/.claude/settings.json (BASH_ENV already set)") ;;
        ERROR:*)  FAILED+=("~/.claude/settings.json: ${BASH_ENV_RESULT#ERROR:}") ;;
    esac
else
    SKIPPED+=("bash-log (not bundled in plugin scripts — skipping)")
fi
# END:bash-log

# --- (g) Monitor scaffolding ---
# Scaffolds .agent/monitor/ (per-project state dir) + .claude/hooks/monitor-nudge.sh
# (non-plugin hook for nudge injection) + .claude/bin/monitor wrapper + registers
# PostToolUse hook in .claude/settings.json. Idempotent.

MONITOR_LIB_DIR=""
MONITOR_HOOK_SRC=""
# SCRIPT_DIR may be the plugin cache dir (normal) or the dev repo's scripts/ dir.
# Look for monitor-lib alongside this script first; fall back to plugin cache.
if [ -d "$SCRIPT_DIR/monitor-lib" ]; then
    MONITOR_LIB_DIR="$SCRIPT_DIR/monitor-lib"
else
    MONITOR_LIB_DIR=$(find ~/.claude/plugins -path '*/playbook/scripts/monitor-lib' -type d 2>/dev/null | sort | head -1)
fi
# monitor-nudge.sh ships in hooks/ (parent of scripts/).
if [ -f "$SCRIPT_DIR/../hooks/monitor-nudge.sh" ]; then
    MONITOR_HOOK_SRC="$SCRIPT_DIR/../hooks/monitor-nudge.sh"
else
    MONITOR_HOOK_SRC=$(find ~/.claude/plugins -path '*/playbook/hooks/monitor-nudge.sh' -type f 2>/dev/null | sort | head -1)
fi

if [ -n "$MONITOR_LIB_DIR" ] && [ -d "$MONITOR_LIB_DIR" ]; then
    MON_DIR="$PROJECT_DIR/.agent/monitor"
    MON_STATE_CREATED=0
    mkdir -p "$MON_DIR"

    # Copy CLAUDE.md (template — always re-copy so updates propagate)
    cp "$MONITOR_LIB_DIR/CLAUDE.md" "$MON_DIR/CLAUDE.md"

    # T121 flat layout: remove stale sandbox.sb (inline PROFILE in launch-monitor
    # is the source of truth) and stale pids/ subdir (single session.md now)
    rm -f "$MON_DIR/sandbox.sb"

    # Copy SSP + mind map stubs ONLY if target doesn't already have them
    # (stubs carry seed scaffolding — actions/dimensions/features/rules skeleton +
    # orientation nodes; monitor edits in place as patterns crystallize)
    for stub in MONITOR_MIND_MAP.md rules.md; do
        if [ ! -f "$MON_DIR/$stub" ]; then
            cp "$MONITOR_LIB_DIR/stubs/$stub" "$MON_DIR/$stub"
            MON_STATE_CREATED=1
        fi
    done

    if [ "$MON_STATE_CREATED" = "1" ]; then
        CREATED+=(".agent/monitor/ (scaffolded)")
    else
        SKIPPED+=(".agent/monitor/ (state files exist)")
    fi

    # Copy monitor-nudge.sh into target's .claude/hooks/
    if [ -n "$MONITOR_HOOK_SRC" ] && [ -f "$MONITOR_HOOK_SRC" ]; then
        mkdir -p "$PROJECT_DIR/.claude/hooks"
        cp "$MONITOR_HOOK_SRC" "$PROJECT_DIR/.claude/hooks/monitor-nudge.sh"
        chmod +x "$PROJECT_DIR/.claude/hooks/monitor-nudge.sh"
        CREATED+=(".claude/hooks/monitor-nudge.sh")
    else
        FAILED+=("monitor-nudge.sh source not found")
    fi

    # Create .claude/bin/monitor wrapper (same pattern as sandbox, tasks)
    create_wrapper "$PROJECT_DIR" monitor
    if [ -f "$PROJECT_DIR/.claude/bin/monitor" ]; then
        CREATED+=(".claude/bin/monitor")
    fi

    # Register PostToolUse hook for monitor-nudge in .claude/settings.json
    NUDGE_HOOK_CMD='bash "$CLAUDE_PROJECT_DIR/.claude/hooks/monitor-nudge.sh"'
    HOOK_RESULT=$(python3 -c "
import json, os
path = '$SETTINGS_FILE_PY'
target_cmd = '''$NUDGE_HOOK_CMD'''
try:
    data = json.loads(open(path).read()) if os.path.exists(path) else {}
    hooks = data.setdefault('hooks', {})
    posthook = hooks.setdefault('PostToolUse', [])
    already = any(
        any(h.get('command') == target_cmd for h in (b.get('hooks') or []))
        for b in posthook if isinstance(b, dict)
    )
    if already:
        print('SKIPPED')
    else:
        posthook.append({'matcher': '', 'hooks': [{'type': 'command', 'command': target_cmd}]})
        open(path, 'w').write(json.dumps(data, indent=2) + '\n')
        print('CREATED')
except Exception as e:
    print('ERROR:' + str(e))
" 2>&1)
    case "$HOOK_RESULT" in
        CREATED)  CREATED+=("settings.json PostToolUse monitor-nudge hook") ;;
        SKIPPED)  SKIPPED+=("settings.json PostToolUse monitor-nudge (already registered)") ;;
        ERROR:*)  FAILED+=("settings.json monitor hook: ${HOOK_RESULT#ERROR:}") ;;
    esac
else
    SKIPPED+=(".agent/monitor/ (monitor-lib not found in plugin)")
fi

# --- (f) Summary ---
echo "playbook init: $PROJECT_NAME"
echo ""
if [ ${#CREATED[@]} -gt 0 ]; then
    echo "Created:"
    for item in "${CREATED[@]}"; do
        echo "  + $item"
    done
fi
if [ ${#SKIPPED[@]} -gt 0 ]; then
    echo "Skipped:"
    for item in "${SKIPPED[@]}"; do
        echo "  - $item"
    done
fi
if [ ${#FAILED[@]} -gt 0 ]; then
    echo "FAILED:"
    for item in "${FAILED[@]}"; do
        echo "  ! $item"
    done
    exit 1
fi
