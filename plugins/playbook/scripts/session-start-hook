#!/bin/bash
# session-start-hook
# SessionStart hook — persists session_id as PLAYBOOK_SESSION_ID env var.
#
# Uses CLAUDE_ENV_FILE to make the env var available in all subsequent
# Bash commands for the session. This enables per-session task state:
# each agent gets its own .agent/sessions/<session_id>/ directory.
#
# Note: CLAUDE_ENV_FILE doesn't work in VSCode extension (as of Feb 2026).
# The PreToolUse hook (task-gate-hook) injects the env var via updatedInput
# as a fallback. This hook is kept for when CLAUDE_ENV_FILE works (CLI).

set -e

# Skip when invoked from the monitor's own claude session (see launch-monitor).
# Log to stderr so the hook's firing is still visible; only gate-enforcement skipped.
if [ "${PLAYBOOK_ROLE:-}" = "monitor" ]; then
    echo "[$(basename "$0")] skip (PLAYBOOK_ROLE=monitor)" >&2
    exit 0
fi

# Source shared lib (same directory)
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$HOOK_DIR/gate-echo-lib.sh"

# Use PID-based session ID via resolve_session_id (gate-echo-lib.sh).
# Walks process tree, finds claude/codex/agy/pi ancestor, uses pid-<that>.
# Same value as pid-$PPID at session-start (claude is direct parent), but
# consistent with all other hooks — no drift risk.
INPUT=$(cat)
SESSION_ID="$(resolve_session_id)"

# Write to CLAUDE_ENV_FILE so it persists for all Bash calls this session
if [ -n "$CLAUDE_ENV_FILE" ]; then
    echo "export PLAYBOOK_SESSION_ID=$SESSION_ID" >> "$CLAUDE_ENV_FILE"
fi

# Auto-provision .claude/bin/ wrappers for playbook projects
PROJECT_DIR=$(find_project_root)
if [ -n "$PROJECT_DIR" ]; then
    AGENT_DIR=$(resolve_agent_dir "$PROJECT_DIR")
    create_wrapper "$PROJECT_DIR" tasks
    create_wrapper "$PROJECT_DIR" sandbox
    # Provider launchers — so existing projects pick up .claude/bin/playbook-<x>
    # on next session start, not just on fresh init.
    create_wrapper "$PROJECT_DIR" playbook-codex
    create_wrapper "$PROJECT_DIR" playbook-agy
    create_wrapper "$PROJECT_DIR" playbook-pi

    # Provision session directory for this session
    SESSION_DIR="$AGENT_DIR/sessions/$SESSION_ID"
    mkdir -p "$SESSION_DIR"

    # GC: sweep stale session dirs from crashed/killed sessions (current_state >24h old)
    SESSIONS_DIR="$AGENT_DIR/sessions"
    if [ -d "$SESSIONS_DIR" ]; then
        find "$SESSIONS_DIR" -maxdepth 2 -name 'current_state' -mtime +0 \
            -exec dirname {} \; 2>/dev/null | xargs rm -rf 2>/dev/null || true
    fi
fi

exit 0
